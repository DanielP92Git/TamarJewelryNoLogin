    <div class="footer-social-links">
      <a class="footer-social-link" href="https://www.instagram.com/tamar_kfir_jewelry/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
      <a class="footer-social-link" href="https://www.facebook.com/tamarkfirjewelry" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
