    </div>

    <div class="footer-right-column">
      <a class="attrib-footer" href="/<%= urlLang %>/workshop"><% if (lang === 'eng') { %>Jewelry Workshop<% } else { %>סדנת תכשיטים<% } %></a>
      <a class="attrib-footer" href="/<%= urlLang %>/about"><% if (lang === 'eng') { %>About<% } else { %>אודות<% } %></a>
    </div>
  </div>

  <div class="footer-social-section">
