<footer class="footer">
  <div class="columns-container">
    <div class="footer-left-column">
      <a class="attrib-footer" href="/<%= urlLang %>"><% if (lang === 'eng') { %>Home<% } else { %>בית<% } %></a>
      <a class="attrib-footer" href="/<%= urlLang %>/necklaces"><% if (lang === 'eng') { %>Necklaces<% } else { %>שרשראות<% } %></a>
      <a class="attrib-footer" href="/<%= urlLang %>/crochet-necklaces"><% if (lang === 'eng') { %>Crochet Necklaces<% } else { %>שרשראות סרוגות<% } %></a>
      <a class="attrib-footer" href="/<%= urlLang %>/hoops"><% if (lang === 'eng') { %>Hoop Earrings<% } else { %>עגילי חישוק<% } %></a>
      <a class="attrib-footer" href="/<%= urlLang %>/dangle"><% if (lang === 'eng') { %>Dangle Earrings<% } else { %>עגילים תלויים<% } %></a>
      <a class="attrib-footer" href="/<%= urlLang %>/bracelets"><% if (lang === 'eng') { %>Bracelets<% } else { %>צמידים<% } %></a>
      <a class="attrib-footer" href="/<%= urlLang %>/unisex"><% if (lang === 'eng') { %>Unisex Jewelry<% } else { %>תכשיטים יוניסקס<% } %></a>
    </div>

    <div class="footer-middle-column">
      <a class="attrib-footer" href="/<%= urlLang %>/policies"><% if (lang === 'eng') { %>Shipping & Cancellation Policy<% } else { %>מדיניות משלוחים וביטולים<% } %></a>
