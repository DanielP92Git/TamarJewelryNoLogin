    <span class="rights-text"><% if (lang === 'eng') { %>&copy; <%= new Date().getFullYear() %> Tamar Kfir Jewelry. All Rights Reserved.<% } else { %>&copy; <%= new Date().getFullYear() %> תכשיטי תמר כפיר. כל הזכויות שמורות.<% } %></span>
