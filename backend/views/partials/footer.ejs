<%
  // Global prototype footer. Real routes; plain <a> (no data-nav) so links
  // navigate on every page, including home where homepage.js toasts data-nav.
  var _eng = lang === 'eng';
%>
<footer class="tk-footer">
  <div class="tk-footer__cols">
    <div class="tk-footer__col">
      <span class="tk-footer__heading"><% if (_eng) { %>Shop<% } else { %>חנות<% } %></span>
      <a class="tk-footer__link" href="/<%= urlLang %>/necklaces"><% if (_eng) { %>Necklaces<% } else { %>שרשראות<% } %></a>
      <a class="tk-footer__link" href="/<%= urlLang %>/crochet-necklaces"><% if (_eng) { %>Crochet Necklaces<% } else { %>שרשראות סרוגות<% } %></a>
      <a class="tk-footer__link" href="/<%= urlLang %>/hoops"><% if (_eng) { %>Hoop Earrings<% } else { %>עגילי חישוק<% } %></a>
      <a class="tk-footer__link" href="/<%= urlLang %>/dangle"><% if (_eng) { %>Dangle Earrings<% } else { %>עגילים תלויים<% } %></a>
    </div>
    <div class="tk-footer__col">
      <span class="tk-footer__heading"><% if (_eng) { %>Customer Care<% } else { %>שירות לקוחות<% } %></span>
      <a class="tk-footer__link" href="/<%= urlLang %>/policies"><% if (_eng) { %>Shipping &amp; Cancellation<% } else { %>משלוחים וביטולים<% } %></a>
      <a class="tk-footer__link" href="/<%= urlLang %>/contact"><% if (_eng) { %>Contact Me<% } else { %>צור קשר<% } %></a>
    </div>
    <div class="tk-footer__col">
      <span class="tk-footer__heading"><% if (_eng) { %>Info<% } else { %>מידע<% } %></span>
      <a class="tk-footer__link" href="/<%= urlLang %>/workshop"><% if (_eng) { %>Jewelry Workshop<% } else { %>סדנת תכשיטים<% } %></a>
      <a class="tk-footer__link" href="/<%= urlLang %>/about"><% if (_eng) { %>About<% } else { %>אודות<% } %></a>
    </div>
    <div class="tk-footer__col">
      <span class="tk-footer__heading"><% if (_eng) { %>Follow Me<% } else { %>עקבו אחרי<% } %></span>
      <div class="tk-footer__social">
        <a class="tk-footer__social-link" href="https://www.instagram.com/tamar_kfir_jewelry/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a class="tk-footer__social-link" href="https://www.facebook.com/tamarkfirjewelry" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898v-2.89h2.54V9.797c0-2.507 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
  <div class="tk-footer__bar">&copy; <%= new Date().getFullYear() %> <% if (_eng) { %>Tamar Kfir Jewelry. All Rights Reserved.<% } else { %>תכשיטי תמר כפיר. כל הזכויות שמורות.<% } %></div>
</footer>
