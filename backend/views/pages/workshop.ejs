<!DOCTYPE html>
<html lang="<%= urlLang %>" dir="<%= dir %>">
<head>
  <%- include('../partials/meta-tags', { title, description, canonical, ogImage, lang, urlLang, alternateUrl, baseUrl, pageStyles }) %>
  <%- bundleScripts %>
  <!-- Microsoft Clarity -->
  <script type="text/javascript">
    (function (c, l, a, r, i, t, y) {
      c[a] =
        c[a] ||
        function () {
          (c[a].q = c[a].q || []).push(arguments);
        };
      t = l.createElement(r);
      t.async = 1;
      t.src = 'https://www.clarity.ms/tag/' + i;
      y = l.getElementsByTagName(r)[0];
      y.parentNode.insertBefore(t, y);
    })(window, document, 'clarity', 'script', 'urnhsmmp4u');
  </script>
</head>
<body id="workshop">
  <%- include('../partials/header', { lang, dir, urlLang }) %>
  <main>
    <h1 id="page-title"><%= lang === 'eng' ? 'MY JEWELRY WORKSHOP' : 'סדנאות התכשיטים שלי' %></h1>

    <section class="workshop-cards-section">
      <div
        class="workshop-cards"
        data-form-url-en="<%= workshops.form.eng.baseUrl %>"
        data-form-entry-en="<%= workshops.form.eng.entryId %>"
        data-form-url-he="<%= workshops.form.heb.baseUrl %>"
        data-form-entry-he="<%= workshops.form.heb.entryId %>"
      >
        <% const wf = lang === 'eng' ? workshops.form.eng : workshops.form.heb; %>
        <% workshops.items.forEach(function (w) {
             const fv = w.formValue ? (lang === 'eng' ? w.formValue.eng : w.formValue.heb) : '';
             const href = fv
               ? wf.baseUrl + '?usp=pp_url&' + wf.entryId + '=' + encodeURIComponent(fv)
               : wf.baseUrl; %>
          <article
            class="workshop-card"
            data-form-value-en="<%= w.formValue ? w.formValue.eng : '' %>"
            data-form-value-he="<%= w.formValue ? w.formValue.heb : '' %>"
            data-name-en="<%= w.name.eng %>"
            data-name-he="<%= w.name.heb %>"
            data-title-en="<%= w.title.eng %>"
            data-title-he="<%= w.title.heb %>"
            data-desc-en="<%= w.desc.eng %>"
            data-desc-he="<%= w.desc.heb %>"
          >
            <div class="workshop-card-image">
              <img
                src="<%= w.image %>"
                alt="<%= lang === 'eng' ? w.title.eng : w.title.heb %>"
                loading="lazy"
                onerror="this.closest('.workshop-card-image').classList.add('is-empty'); this.remove();"
              />
            </div>
            <h3 class="workshop-card-title"><%= lang === 'eng' ? w.title.eng : w.title.heb %></h3>
            <p class="workshop-card-desc"><%= lang === 'eng' ? w.desc.eng : w.desc.heb %></p>
            <a
              class="workshop-card-btn"
              href="<%= href %>"
              target="_blank"
              rel="noopener noreferrer"
            ><%= lang === 'eng' ? 'More Details' : 'לפרטים נוספים' %></a>
          </article>
        <% }); %>
      </div>
    </section>

    <div class="workshop-costs">
      <div class="contact-container">
        <div class="contact-block">
          <a href="https://wa.me/972524484763" class="whatsapp-atr">
            <img
              src="/imgs/svgs/whatsapp.svg"
              class="whatsapp-svg"
              alt="<%= lang === 'eng' ? 'WhatsApp contact' : 'צור קשר בוואטסאפ' %>"
            />
          </a>
          <span class="contact-label"><%= lang === 'eng' ? 'Whatsapp:' : 'וואטסאפ:' %></span>
          <p class="contact-value"><%= lang === 'eng' ? '+972-524484763' : '052-4484763' %></p>
        </div>
        <div class="contact-block">
          <a href="tel:+972524484763" class="contact-link">
            <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </a>
          <span class="contact-label"><%= lang === 'eng' ? 'Tel.:' : 'נייד:' %></span>
          <p class="contact-value"><%= lang === 'eng' ? '+972-524484763' : '052-4484763' %></p>
        </div>
        <div class="contact-block contact-block-last">
          <a href="mailto:tamarkfir91@gmail.com" class="contact-link">
            <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="M22 4l-10 8L2 4"></path>
            </svg>
          </a>
          <span class="contact-label"><%= lang === 'eng' ? 'Email:' : 'דוא"ל:' %></span>
          <p class="contact-value">tamarkfir91@gmail.com</p>
        </div>
      </div>
      <span class="workshop-cost-note"><%= lang === 'eng' ? "*Each workshop takes an hour and a half. For any questions please don't hesitate to contact me." : '*כל סדנה נמשכת שעה וחצי. לכל שאלה, אל תהססי לפנות אלי.' %></span>    </div>
  </main>
  <%- include('../partials/footer', { lang, urlLang }) %>
</body>
</html>
