            </div>
            <div class="pricing-card-bottom">
              <p class="pricing-card-desc"><%= lang === 'eng' ? 'A personal and focused experience. All attention is dedicated to you.' : 'חוויה אישית וממוקדת. כל תשומת הלב מוקדשת לך.' %></p>
            </div>
          </div>
          <div class="pricing-card">
            <div class="pricing-card-top">
              <h3 class="pricing-card-title"><%= lang === 'eng' ? '2 Participants' : '2 משתתפות' %></h3>
              <span class="pricing-card-price"><%= lang === 'eng' ? '220 NIS' : '220 ש"ח' %></span>
            </div>
            <div class="pricing-card-bottom">
              <p class="pricing-card-desc"><%= lang === 'eng' ? 'A couples or friends workshop. Per participant.' : 'סדנא זוגית או עם חברה. לכל משתתפת.' %></p>
            </div>
          </div>
          <div class="pricing-card">
            <div class="pricing-card-top">
