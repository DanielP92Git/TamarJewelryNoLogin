              <span class="pricing-card-price"><%= lang === 'eng' ? '200 NIS' : '200 ש"ח' %></span>
            </div>
            <div class="pricing-card-bottom">
              <p class="pricing-card-desc"><%= lang === 'eng' ? 'A group workshop, festive and fun. Per participant.' : 'סדנא קבוצתית, חגיגית וכיפית. לכל משתתפת.' %></p>
            </div>
          </div>
        </div>
      </div>
      <div class="contact-container">
