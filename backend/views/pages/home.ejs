<!doctype html>
<html lang="<%= urlLang %>" dir="<%= dir %>">
  <head>
    <%- include('../partials/meta-tags', { title, description, canonical, ogImage, lang, urlLang, alternateUrl, baseUrl, pageStyles }) %>

    <!-- Organization JSON-LD structured data (SCHEMA-04) -->
    <script type="application/ld+json">
    <%- JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Tamar Kfir Jewelry",
      "url": baseUrl,
      "logo": baseUrl + "/imgs/icons/favicon.png",
      "description": lang === 'eng' ? "Handmade jewelry crafted with love in Jerusalem" : "תכשיטים בעבודת יד מירושלים",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Customer Service",
        "availableLanguage": ["English", "Hebrew"]
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Jerusalem",
        "addressCountry": "IL"
      },
      "sameAs": [
        "https://www.instagram.com/tamar_kfir_jewelry/",
        "https://www.facebook.com/tamarkfirjewelry"
      ]
    }, null, 2) %>
    </script>

    <%- bundleScripts %>
    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = 'https://www.clarity.ms/tag/' + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, 'clarity', 'script', 'urnhsmmp4u');
    </script>
  </head>

  <body id="home">
    <%- include('../partials/header', { lang, dir, urlLang, heroNav, activeNav }) %>

    <% if (typeof require !== 'undefined' || true) { %>
    <script>
    (function() {
      if (new URLSearchParams(window.location.search).get('success') !== 'true') return;
      var isHe = '<%= urlLang %>' === 'he';
      var banner = document.createElement('div');
      banner.id = 'order-success-banner';
      banner.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:9999;background:#16a34a;color:#fff;text-align:center;padding:14px 40px;font-size:16px;font-weight:600;direction:' + (isHe ? 'rtl' : 'ltr');
      banner.textContent = isHe ? 'ההזמנה בוצעה בהצלחה! תודה רבה' : 'Order placed successfully! Thank you';
      var close = document.createElement('button');
      close.textContent = '×';
      close.style.cssText = 'position:absolute;top:50%;right:12px;transform:translateY(-50%);background:none;border:none;color:#fff;font-size:22px;cursor:pointer;padding:4px 8px';
      close.onclick = function() { banner.remove(); };
      banner.appendChild(close);
      document.body.prepend(banner);
      // Auto-dismiss after 8 seconds
      setTimeout(function() { if (banner.parentNode) banner.remove(); }, 8000);
      // Clean URL
      history.replaceState(null, '', window.location.pathname);
    })();
    </script>
    <% } %>

    <div class="tk-home">

      <!-- ============ HERO ============ -->
      <section class="tk-hero">
        <img class="tk-hero__img" id="tk-hero-img" src="/imgs/homepage/imagery/hero-main.webp" alt="" />
        <div class="tk-hero__scrim"></div>
        <div class="tk-hero__copy">
          <p class="tk-hero__eyebrow"><% if (lang === 'eng') { %>Handmade in Jerusalem<% } else { %>בעבודת יד מירושלים<% } %></p>
          <p class="tk-hero__title"><% if (lang === 'eng') { %>One of a kind<br />in mind<% } else { %>אחד ויחיד<br />במחשבה<% } %></p>
          <a class="tk-btn tk-btn--outline tk-btn--lg" href="#tk-shop" id="tk-hero-cta"><% if (lang === 'eng') { %>Discover the Collection<% } else { %>גלו את הקולקציה<% } %></a>
        </div>
      </section>

      <!-- ============ COLLECTIONS ============ -->
      <section class="tk-section" id="tk-shop">
        <div class="tk-center">
          <p class="tk-eyebrow"><% if (lang === 'eng') { %>Collections<% } else { %>קולקציות<% } %></p>
          <h2 class="tk-h2"><% if (lang === 'eng') { %>Shop by Category<% } else { %>קנו לפי קטגוריה<% } %></h2>
        </div>
        <div class="tk-cat-grid" id="tk-cat-grid">
          <a class="tk-cat" href="/<%= urlLang %>/crochet-necklaces">
            <img src="/imgs/homepage/categories/crochet.webp" alt="<% if (lang === 'eng') { %>Crochet Necklaces<% } else { %>שרשראות סרוגות<% } %>" />
            <span class="tk-cat__label"><% if (lang === 'eng') { %>Crochet Necklaces<% } else { %>שרשראות סרוגות<% } %></span>
          </a>
          <a class="tk-cat" href="/<%= urlLang %>/hoops">
            <img src="/imgs/homepage/categories/hoops.webp" alt="<% if (lang === 'eng') { %>Hoop Earrings<% } else { %>עגילי חישוק<% } %>" />
            <span class="tk-cat__label"><% if (lang === 'eng') { %>Hoop Earrings<% } else { %>עגילי חישוק<% } %></span>
          </a>
          <a class="tk-cat" href="/<%= urlLang %>/dangle">
            <img src="/imgs/homepage/categories/dangle.webp" alt="<% if (lang === 'eng') { %>Dangle Earrings<% } else { %>עגילים תלויים<% } %>" />
            <span class="tk-cat__label"><% if (lang === 'eng') { %>Dangle Earrings<% } else { %>עגילים תלויים<% } %></span>
          </a>
          <a class="tk-cat" href="/<%= urlLang %>/necklaces">
            <img src="/imgs/homepage/categories/necklaces.webp" alt="<% if (lang === 'eng') { %>Necklaces<% } else { %>שרשראות<% } %>" />
            <span class="tk-cat__label"><% if (lang === 'eng') { %>Necklaces<% } else { %>שרשראות<% } %></span>
          </a>
        </div>
      </section>

      <!-- ============ MAKER STORY ============ -->
      <section class="tk-story">
        <div class="tk-story__inner">
          <div class="tk-story__media">
            <img src="/imgs/homepage/imagery/hero-alt.webp" alt="<% if (lang === 'eng') { %>A handmade pendant necklace<% } else { %>שרשרת תליון בעבודת יד<% } %>" />
          </div>
          <div class="tk-story__body">
            <p class="tk-eyebrow"><% if (lang === 'eng') { %>The Maker<% } else { %>היוצרת<% } %></p>
            <h2 class="tk-story__title"><% if (lang === 'eng') { %>A bit about me<br />and my jewelry<% } else { %>קצת עליי<br />ועל התכשיטים שלי<% } %></h2>
            <% if (lang === 'eng') { %>
            <p class="tk-story__p">I have been making jewelry since I was twelve, and I have never really stopped. Each piece is handmade in beautiful, historic Jerusalem — crocheted with fine metallic threads and a colour combination that is never quite repeated.</p>
            <p class="tk-story__p">It is where I find my calm, and how I get to share a little colour with appreciative customers all over the world. No two pieces sit the same way twice — and that is exactly the point.</p>
            <% } else { %>
            <p class="tk-story__p">אני יוצרת תכשיטים מאז גיל שתים־עשרה, ומעולם לא ממש הפסקתי. כל פריט נעשה בעבודת יד בירושלים ההיסטורית והיפה — סרוג בחוטים מתכתיים דקים ובשילוב צבעים שלעולם אינו חוזר על עצמו בדיוק.</p>
            <p class="tk-story__p">כאן אני מוצאת את השקט שלי, וכך אני זוכה לחלוק מעט צבע עם לקוחות אוהבים מכל העולם. אין שני פריטים זהים — וזה בדיוק העניין.</p>
            <% } %>
            <div>
              <a class="tk-btn tk-btn--ghost" href="/<%= urlLang %>/about"><% if (lang === 'eng') { %>Read my story<% } else { %>קראו את הסיפור שלי<% } %></a>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ FEATURED ============ -->
      <% if (featuredProducts && featuredProducts.length > 0) { %>
      <section class="tk-section tk-section--wide">
        <div class="tk-center">
          <p class="tk-eyebrow"><% if (lang === 'eng') { %>New &amp; Loved<% } else { %>חדש ואהוב<% } %></p>
          <h2 class="tk-h2"><% if (lang === 'eng') { %>Featured Pieces<% } else { %>פריטים נבחרים<% } %></h2>
        </div>
        <div class="tk-prod-grid" id="tk-prod-grid">
          <% featuredProducts.forEach(function(product) { %>
          <%
            // Gallery image construction (copy of category.ejs lines 70-101)
            let galleryImages = [];
            if (Array.isArray(product.images) && product.images.length > 0) {
              galleryImages = product.images.map(function(img) {
                return {
                  desktop: img.desktop || '',
                  mobile: img.mobile || '',
                  publicDesktop: img.publicDesktop || '',
                  publicMobile: img.publicMobile || ''
                };
              });
            } else {
              if (product.mainImage && typeof product.mainImage === 'object') {
                galleryImages.push({
                  desktop: product.mainImage.desktop || '',
                  mobile: product.mainImage.mobile || '',
                  publicDesktop: product.mainImage.publicDesktop || '',
                  publicMobile: product.mainImage.publicMobile || ''
                });
              }
              if (Array.isArray(product.smallImages)) {
                product.smallImages.forEach(function(si) {
                  if (si && typeof si === 'object') {
                    galleryImages.push({
                      desktop: si.desktop || '',
                      mobile: si.mobile || '',
                      publicDesktop: si.publicDesktop || '',
                      publicMobile: si.publicMobile || ''
                    });
                  }
                });
              }
            }
            const desktopImage = product.images?.[0]?.publicDesktop || product.images?.[0]?.desktop || product.mainImage?.publicDesktop || product.mainImage?.desktop || '';
            const productName = lang === 'heb'
              ? (product.name_he || product.name_en || product.name)
              : (product.name_en || product.name);
            const hasDiscount = product.discount_percentage > 0 && (product.original_usd_price > product.usd_price || product.original_ils_price > product.ils_price);
          %>
          <div class="tk-prod"
               data-id="<%= product.id %>"
               data-quant="<%= product.quantity %>"
               data-usd-price="<%= Math.round(product.usd_price || 0) %>"
               data-ils-price="<%= Math.round(product.ils_price || 0) %>"
               data-original-usd-price="<%= Math.round(product.original_usd_price || product.usd_price || 0) %>"
               data-original-ils-price="<%= Math.round(product.original_ils_price || product.ils_price || 0) %>"
               data-slug="<%= product.slug %>"
               data-name-en="<%= product.name_en || product.name %>"
               data-name-he="<%= product.name_he || '' %>"
               data-description-en="<%= product.description_en || product.description || '' %>"
               data-description-he="<%= product.description_he || '' %>"
               data-sku="<%= product.sku || '' %>"
               data-images="<%= JSON.stringify(galleryImages) %>">
            <div class="tk-prod__media">
              <img src="<%= desktopImage %>" alt="<%= productName %>" loading="lazy" />
              <% if (hasDiscount) { %>
              <div class="tk-prod__badge"><span class="tk-badge tk-badge--gold">Sale</span></div>
              <% } %>
            </div>
            <div class="tk-prod__title-wrap"><h3 class="tk-prod__title"><%= productName %></h3></div>
            <div class="tk-prod__price"><!-- hydrated by homepage.js --></div>
            <button class="tk-prod__add" type="button"><% if (lang === 'eng') { %>Add to Cart<% } else { %>הוסף לעגלה<% } %></button>
          </div>
          <% }); %>
        </div>
        <div class="tk-center" style="margin-top: 3.2rem;">
          <a class="tk-btn tk-btn--primary" href="/<%= urlLang %>/necklaces"><% if (lang === 'eng') { %>View All Jewelry<% } else { %>לכל התכשיטים<% } %></a>
        </div>
      </section>
      <% } %>

      <!-- ============ NEWSLETTER ("Stay in touch") ============ -->
      <!-- Temporarily removed per request (2026-06-28). The full bilingual
           markup is in git history and the homepage.css .tk-news* styles
           remain; homepage.js newsletter wiring is guarded for its absence.
           To restore: re-add the <section class="tk-news"> block here. -->

      <!-- ============ FLOATING WHATSAPP + TOAST ============ -->
      <a class="tk-whatsapp" href="https://wa.me/972524484763" id="tk-whatsapp" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
        <img src="/imgs/homepage/icons/whatsapp.svg" alt="" />
      </a>
      <div class="tk-toast" id="tk-toast"></div>

    </div>

    <%- include('../partials/footer', { lang, urlLang }) %>

    <!-- Featured-product modal shell (populated by homepage.js openProductModal) -->
    <div class="tk-modal" id="tk-modal"></div>

    <script src="/js/homepage.js" defer></script>
  </body>
</html>
